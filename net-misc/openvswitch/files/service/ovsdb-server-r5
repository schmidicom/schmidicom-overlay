[Unit]
Description=Open vSwitch database server
Documentation=man:ovsdb-server
After=network-pre.target
Before=network.target

[Service]
LimitNOFILE=1048576
Type=forking
Restart=on-failure
WorkingDirectory=/run/openvswitch
EnvironmentFile=-/etc/conf.d/openvswitch
PIDFile=/run/openvswitch/ovsdb-server.pid
ExecStart=/usr/bin/ovsdb-server --remote=punix:/run/openvswitch/db.sock --pidfile=/run/openvswitch/ovsdb-server.pid --detach $OVSDB_SERVER_OPTS
ExecReload=/usr/bin/ovs-appctl --target=ovsdb-server ovsdb-server/reload
ExecStop=/usr/bin/ovs-appctl --target=ovsdb-server exit

[Install]
WantedBy=multi-user.target
